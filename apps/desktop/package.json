    "@pixi/display": "6.5.10",
    "@pixi/loaders": "6.5.10",
    "@pixi/math": "6.5.10",
    "@pixi/sprite": "6.5.10",
    "@pixi/utils": "6.5.10",
    "@pixiv/three-vrm": "^3.4.0",
    "adm-zip": "^0.5.17",
    "apexcharts": "^5.16.0",
    "better-sqlite3": "^11",
    "lucide-vue-next": "^1.0.0",
    "pixi-live2d-display": "0.4.0",
